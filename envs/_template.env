# =========================================================================
# 店舗デプロイ用envテンプレート
#
# 使い方:
#   1. cp envs/_template.env envs/<SHOP_ID>-<SHOP_NAME>.env
#      例: cp envs/_template.env envs/57-konishi.env
#   2. 下記の値を該当店舗向けに書き換える
#   3. ./scripts/deploy.sh <SHOP_ID> でデプロイ
#      例: ./scripts/deploy.sh 57
#
# 値の出どころ:
#   - SHOP_ID / SHOP_NAME / SHOP_PORT / DEPLOY_HOST: shop_configs.rpa_server_url
#   - DEPLOY_USER: RPAサーバのSSHユーザ (RPA01=alma, RPA03/04=centos)
#   - DEPLOY_BASTION_*: 全店舗共通の踏み台情報
#
# 注意: envs/<SHOP_ID>-*.env は .gitignore 対象。
#       本テンプレートのみリポジトリにコミットされる。
# =========================================================================

# ===== コンテナ実行時設定（docker compose の env_file で読まれる）=====
PORT=3000
ENABLE_SCREENSHOT=true
SCREENSHOT_DIR=./screenshots
KEEP_ALIVE_INTERVAL_MS=600000

# ===== 店舗識別（docker-compose.shop.yml の変数展開で参照）=====
# SHOP_ID: DB shop_configs.id (51/57/121/128/165) または 'staging'
SHOP_ID=
# SHOP_NAME: container_name デフォルトのサフィックス、screenshots ディレクトリ識別子
SHOP_NAME=
# SHOP_PORT: RPAサーバのホスト側公開ポート (3011/3012/3013 等)
SHOP_PORT=
# CONTAINER_NAME: (任意) 既存運用の互換のためコンテナ名を明示する場合
# 未指定なら smartcall-easyapo-<SHOP_NAME> が自動採用される
# 例) ビーンズ歯科: CONTAINER_NAME=beans-shika
#     ゆきデンタル: CONTAINER_NAME=yuki-dental
CONTAINER_NAME=

# ===== デプロイ先サーバ情報（scripts/deploy.sh が参照）=====
# DEPLOY_HOST: 内部ネットワーク内のRPAサーバIP
DEPLOY_HOST=
# DEPLOY_USER: RPAサーバへのSSHユーザ (alma / centos)
DEPLOY_USER=
# DEPLOY_BASTION_HOST: 踏み台サーバのグローバルIP
DEPLOY_BASTION_HOST=153.126.214.207
# DEPLOY_BASTION_USER: 踏み台SSHユーザ
DEPLOY_BASTION_USER=centos
# DEPLOY_SSH_KEY: SSH秘密鍵パス（踏み台・RPAサーバ共通）
DEPLOY_SSH_KEY=~/.ssh/milestone
